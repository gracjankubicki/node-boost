{
  "name": "@node-boost/node-boost",
  "version": "0.1.0",
  "description": "CLI and MCP guidance layer for Node/React projects.",
  "type": "module",
  "license": "MIT",
  "author": "Gracjan Kubicki",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gracjankubicki/node-boost.git"
  },
  "bugs": {
    "url": "https://github.com/gracjankubicki/node-boost/issues"
  },
  "homepage": "https://github.com/gracjankubicki/node-boost#readme",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "node",
    "react",
    "nextjs",
    "vite",
    "codex",
    "claude-code",
    "cursor",
    "mcp",
    "architecture",
    "audit",
    "agent-skills"
  ],
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "node-boost": "./dist/cli.js"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "resources",
    "schema.json",
    "CHANGELOG.md",
    "LICENSE.md",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build:schema && tsup",
    "build:schema": "tsx scripts/generate-schema.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "check": "npm run typecheck && npm run lint && npm test && npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "citty": "^0.2.2",
    "picomatch": "^4.0.5",
    "smol-toml": "^1.7.0",
    "ts-morph": "^28.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@types/picomatch": "^4.0.3",
    "eslint": "^10.6.0",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
