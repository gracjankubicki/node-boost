{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://node-boost.dev/schema.json",
  "title": "node-boost configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "generatedWith", "stack"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "const": 1
    },
    "generatedWith": {
      "type": "string",
      "minLength": 1
    },
    "stack": {
      "enum": ["next", "vite-react", "react-generic", "unknown"]
    },
    "agents": {
      "type": "array",
      "items": {
        "enum": ["claude-code", "codex", "cursor"]
      },
      "default": []
    },
    "features": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "guidelines": { "type": "boolean", "default": true },
        "skills": { "type": "boolean", "default": true },
        "mcp": { "type": "boolean", "default": true },
        "architecture": { "type": "boolean", "default": true },
        "hooks": { "type": "boolean", "default": false }
      },
      "default": {
        "guidelines": true,
        "skills": true,
        "mcp": true,
        "architecture": true,
        "hooks": false
      }
    },
    "architectures": {
      "type": "array",
      "items": {
        "enum": [
          "feature-modules",
          "server-first-components",
          "data-access-layer",
          "typed-contracts",
          "state-management",
          "custom-hooks",
          "component-composition",
          "styling-tailwind",
          "testing-strategy",
          "error-loading-boundaries"
        ]
      },
      "default": []
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "exclude": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "rules": {
          "type": "object",
          "additionalProperties": {
            "enum": ["off", "warn", "err"]
          },
          "default": {}
        },
        "ruleOptions": {
          "type": "object",
          "additionalProperties": {
            "type": "object"
          },
          "default": {}
        }
      },
      "default": {
        "exclude": [],
        "rules": {},
        "ruleOptions": {}
      }
    }
  }
}
