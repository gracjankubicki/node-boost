{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "number",
      "const": 1
    },
    "generatedWith": {
      "type": "string",
      "minLength": 1
    },
    "stack": {
      "type": "string",
      "enum": [
        "next",
        "vite-react",
        "react-generic",
        "unknown"
      ]
    },
    "agents": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "claude-code",
          "codex",
          "cursor"
        ]
      }
    },
    "hookAgents": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "claude-code",
          "codex",
          "cursor"
        ]
      }
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "features": {
      "default": {
        "guidelines": true,
        "skills": true,
        "mcp": true,
        "architecture": true,
        "hooks": false
      },
      "type": "object",
      "properties": {
        "guidelines": {
          "default": true,
          "type": "boolean"
        },
        "skills": {
          "default": true,
          "type": "boolean"
        },
        "mcp": {
          "default": true,
          "type": "boolean"
        },
        "architecture": {
          "default": true,
          "type": "boolean"
        },
        "hooks": {
          "default": false,
          "type": "boolean"
        }
      },
      "required": [
        "guidelines",
        "skills",
        "mcp",
        "architecture",
        "hooks"
      ],
      "additionalProperties": false
    },
    "architectures": {
      "default": [],
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "string",
            "enum": [
              "feature-modules",
              "server-first-components",
              "data-access-layer",
              "typed-contracts",
              "state-management",
              "custom-hooks",
              "component-composition",
              "styling-tailwind",
              "testing-strategy",
              "error-loading-boundaries",
              "secure-by-default",
              "modern-typescript",
              "ui-states"
            ]
          },
          {
            "type": "string"
          },
          {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "const": "feature-modules"
              },
              "boundary": {
                "default": "public-api",
                "type": "string",
                "enum": [
                  "public-api",
                  "forbid"
                ]
              }
            },
            "required": [
              "name",
              "boundary"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "enum": [
                  "server-first-components",
                  "data-access-layer",
                  "typed-contracts",
                  "state-management",
                  "custom-hooks",
                  "component-composition",
                  "styling-tailwind",
                  "testing-strategy",
                  "error-loading-boundaries",
                  "secure-by-default",
                  "modern-typescript",
                  "ui-states"
                ]
              }
            },
            "required": [
              "name"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "variant": {
                "type": "string"
              }
            },
            "required": [
              "name"
            ],
            "additionalProperties": false
          }
        ]
      }
    },
    "audit": {
      "default": {
        "exclude": [],
        "rules": {},
        "ruleOptions": {}
      },
      "type": "object",
      "properties": {
        "exclude": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rules": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string",
            "enum": [
              "NB-ARCH-001",
              "NB-ARCH-002",
              "NB-ARCH-003",
              "NB-ARCH-004",
              "NB-ARCH-005",
              "NB-ARCH-006",
              "NB-ARCH-007",
              "NB-ARCH-008",
              "NB-ARCH-009",
              "NB-ARCH-010",
              "NB-ARCH-011",
              "NB-ARCH-012",
              "NB-ARCH-013",
              "NB-ARCH-014"
            ]
          },
          "additionalProperties": {
            "type": "string",
            "enum": [
              "off",
              "warn",
              "err"
            ]
          }
        },
        "ruleOptions": {
          "default": {},
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "NB-ARCH-001": {
              "type": "object",
              "properties": {
                "featuresDir": {
                  "type": "string",
