{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "number",
      "const": 1
    },
    "generatedWith": {
      "type": "string",
      "minLength": 1
    },
    "stack": {
      "type": "string",
      "enum": [
        "next",
        "vite-react",
        "react-generic",
        "unknown"
      ]
    },
    "agents": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "claude-code",
          "codex",
          "cursor"
        ]
      }
    },
    "features": {
      "default": {
        "guidelines": true,
        "skills": true,
        "mcp": true,
        "architecture": true,
        "hooks": false
      },
      "type": "object",
      "properties": {
        "guidelines": {
          "default": true,
          "type": "boolean"
        },
        "skills": {
          "default": true,
          "type": "boolean"
        },
        "mcp": {
          "default": true,
          "type": "boolean"
        },
        "architecture": {
          "default": true,
          "type": "boolean"
        },
        "hooks": {
          "default": false,
          "type": "boolean"
        }
      },
      "required": [
        "guidelines",
        "skills",
        "mcp",
        "architecture",
        "hooks"
      ],
      "additionalProperties": false
    },
    "architectures": {
      "default": [],
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "string",
            "enum": [
              "feature-modules",
              "server-first-components",
              "data-access-layer",
              "typed-contracts",
              "state-management",
              "custom-hooks",
              "component-composition",
              "styling-tailwind",
              "testing-strategy",
              "error-loading-boundaries",
              "secure-by-default",
              "modern-typescript",
              "ui-states"
            ]
          },
          {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "const": "feature-modules"
              },
              "boundary": {
                "default": "public-api",
                "type": "string",
                "enum": [
                  "public-api",
                  "forbid"
                ]
              }
            },
            "required": [
              "name",
              "boundary"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "enum": [
                  "server-first-components",
                  "data-access-layer",
                  "typed-contracts",
                  "state-management",
                  "custom-hooks",
                  "component-composition",
                  "styling-tailwind",
                  "testing-strategy",
                  "error-loading-boundaries",
                  "secure-by-default",
                  "modern-typescript",
                  "ui-states"
                ]
              }
            },
            "required": [
              "name"
            ],
            "additionalProperties": false
          }
        ]
      }
    },
    "audit": {
      "default": {
        "exclude": [],
        "rules": {},
        "ruleOptions": {}
      },
      "type": "object",
      "properties": {
        "exclude": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rules": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "string",
            "enum": [
              "off",
              "warn",
              "err"
            ]
          }
        },
        "ruleOptions": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {}
          }
        }
      },
      "required": [
        "exclude",
        "rules",
        "ruleOptions"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "version",
    "generatedWith",
    "stack",
    "agents",
    "features",
    "architectures",
    "audit"
  ],
  "additionalProperties": false,
  "$id": "https://node-boost.dev/schema.json",
  "title": "node-boost configuration"
}
