              "additionalProperties": false
            },
            "NB-ARCH-002": {
              "type": "object",
              "properties": {
                "featuresDir": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "additionalProperties": false
            },
            "NB-ARCH-003": {
              "type": "object",
              "properties": {},
              "additionalProperties": false
            },
            "NB-ARCH-004": {
              "type": "object",
              "properties": {},
              "additionalProperties": false
            },
            "NB-ARCH-005": {
              "type": "object",
              "properties": {
                "dataLayerGlobs": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "additionalProperties": false
            },
            "NB-ARCH-006": {
              "type": "object",
              "properties": {
                "dataLayerGlobs": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "additionalProperties": false
            },
            "NB-ARCH-007": {
              "type": "object",
              "properties": {
                "dataLayerGlobs": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "additionalProperties": false
            },
            "NB-ARCH-008": {
              "type": "object",
              "properties": {
                "envFiles": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "additionalProperties": false
            },
            "NB-ARCH-009": {
              "type": "object",
              "properties": {
                "dataLayerGlobs": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "additionalProperties": false
            },
            "NB-ARCH-010": {
              "type": "object",
              "properties": {},
              "additionalProperties": false
            },
            "NB-ARCH-011": {
              "type": "object",
              "properties": {
                "sanitizers": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "additionalProperties": false
            },
            "NB-ARCH-012": {
              "type": "object",
              "properties": {},
              "additionalProperties": false
            },
            "NB-ARCH-013": {
              "type": "object",
              "properties": {},
              "additionalProperties": false
            },
            "NB-ARCH-014": {
              "type": "object",
              "properties": {},
              "additionalProperties": false
            }
          }
        }
      },
      "required": [
        "exclude",
        "rules",
        "ruleOptions"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "version",
    "generatedWith",
    "stack",
    "agents",
    "features",
    "architectures",
    "audit"
  ],
  "additionalProperties": false,
  "$id": "https://node-boost.dev/schema.json",
  "title": "node-boost configuration"
}
